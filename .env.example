# ================================================================
# Recipe Preparation Agent — Environment Variables
# Copy this file to .env and fill in your values
# ================================================================

# ── IBM watsonx.ai Credentials ─────────────────────────────────
# Get these from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=

# Get this from: https://dataplatform.cloud.ibm.com/wx/home
IBM_PROJECT_ID=

# watsonx.ai API endpoint (choose region closest to you)
# Options: https://us-south.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://eu-gb.ml.cloud.ibm.com
#          https://jp-tok.ml.cloud.ibm.com
#          https://au-syd.ml.cloud.ibm.com
WATSONX_URL=
# ── Model Selection (use a model supported by YOUR deployment) ───
# Check supported models at: https://dataplatform.cloud.ibm.com
#
# au-syd deployment supports:

# ibm/granite-3-1-8b-base            ← Granite base (weaker for chat)
# ibm/granite-8b-code-instruct       ← Code tasks only
#
# us-south deployment supports:
# ibm/granite-3-8b-instruct          ← Best Granite chat model
# ibm/granite-3-2b-instruct          ← Faster Granite
GRANITE_MODEL_ID=ibm/granite-3-1-8b-base
# ── Flask Configuration ─────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_secure_random_secret_key_here

# Set to "development" for hot-reload, "production" for deployment
FLASK_ENV=development

# Port to run the app on
PORT=5000

# ── ChromaDB Configuration ──────────────────────────────────────
# Directory where ChromaDB persists vector data
CHROMA_PERSIST_DIR=.chroma_db
